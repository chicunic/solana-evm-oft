{
  "exclude": ["node_modules"],
  "include": ["deploy", "tasks", "test", "hardhat.config.ts", "type-extensions.ts", "layerzero.config.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "rootDir": ".",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
